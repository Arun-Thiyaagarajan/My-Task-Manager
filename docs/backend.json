
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile within the TaskFlow application, storing authentication-related details and linking to their data.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "email": {
          "type": "string",
          "description": "The user's email address, used as a login credential and for email verification.",
          "format": "email"
        },
        "username": {
          "type": "string",
          "description": "The user's chosen username."
        },
        "photoURL": {
          "type": "string",
          "description": "The URL or Base64 data of the user's profile photo."
        },
        "role": {
          "type": "string",
          "description": "The user's role within the system.",
          "enum": ["admin", "user"]
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the user profile was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp indicating when the user profile was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "createdAt",
        "updatedAt"
      ]
    },
    "UserPreferences": {
      "title": "UserPreferences",
      "type": "object",
      "properties": {
        "viewMode": { "type": "string", "enum": ["grid", "table"] },
        "sortDescriptor": { "type": "string" },
        "dateView": { "type": "string", "enum": ["all", "monthly", "yearly"] },
        "taskFilters": { "type": "object" },
        "noteFilters": { "type": "object" },
        "sidebarPosition": { "type": "string", "enum": ["left", "right"] },
        "favoritesOnly": { "type": "boolean" }
      }
    },
    "CompanyMetadata": {
      "title": "CompanyMetadata",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "Task": {
      "title": "Task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "summary": { "type": "string" },
        "isFavorite": { "type": "boolean" },
        "reminder": { "type": "string" },
        "reminderExpiresAt": { "type": "string" },
        "repositories": { "type": "array", "items": { "type": "string" } },
        "azureWorkItemId": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "prLinks": { "type": "object" },
        "deploymentStatus": { "type": "object" },
        "deploymentDates": { "type": "object" },
        "relevantEnvironments": { "type": "array", "items": { "type": "string" } },
        "developers": { "type": "array", "items": { "type": "string" } },
        "testers": { "type": "array", "items": { "type": "string" } },
        "comments": { "type": "array" },
        "attachments": { "type": "array" },
        "customFields": { "type": "object" }
      }
    },
    "Feedback": {
      "title": "Feedback",
      "type": "object",
      "description": "User submitted support requests, bug reports, or feature suggestions.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["Bug Report", "Feature Request", "Suggestion", "Other"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "contactEmail": { "type": "string", "format": "email" },
        "status": { "type": "string", "enum": ["Submitted", "Reviewed", "Closed", "In Progress", "Resolved"] },
        "appVersion": { "type": "string" },
        "environment": { "type": "string" },
        "attachments": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "userName": { "type": "string" }
      },
      "required": ["id", "type", "title", "description", "status", "createdAt"]
    },
    "AppNotification": {
      "title": "AppNotification",
      "type": "object",
      "description": "A real-time notification for users or administrators regarding system events or support activity.",
      "properties": {
        "id": { "type": "string" },
        "recipientId": { "type": "string", "description": "The UID of the recipient user, or 'admin' for administrative alerts." },
        "type": { "type": "string", "enum": ["user_request", "admin_reply", "system"] },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "link": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" }
      },
      "required": ["id", "recipientId", "type", "title", "message", "link", "timestamp", "read"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "User profile data."
        }
      },
      {
        "path": "/users/{userId}/preferences/settings",
        "definition": {
          "entityName": "UserPreferences",
          "description": "User-specific application settings and preferences."
        }
      },
      {
        "path": "/users/{userId}/companies/{companyId}",
        "definition": {
          "entityName": "CompanyMetadata",
          "description": "Metadata for a company owned by the user."
        }
      },
      {
        "path": "/users/{userId}/companies/{companyId}/tasks/{taskId}",
        "definition": {
          "entityName": "Task",
          "description": "Tasks associated with a specific company."
        }
      },
      {
        "path": "/users/{userId}/companies/{companyId}/notes/{noteId}",
        "definition": {
          "entityName": "Note",
          "description": "Notes associated with a specific company."
        }
      },
      {
        "path": "/feedback/{feedbackId}",
        "definition": {
          "entityName": "Feedback",
          "description": "Global collection for user support and feedback."
        }
      },
      {
        "path": "/notifications/{notificationId}",
        "definition": {
          "entityName": "AppNotification",
          "description": "Collection of real-time notifications for users and administrators."
        }
      }
    ]
  }
}
