
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile within the TaskFlow application, storing authentication-related details and linking to their data.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "email": {
          "type": "string",
          "description": "The user's email address, used as a login credential and for email verification.",
          "format": "email"
        },
        "username": {
          "type": "string",
          "description": "The user's chosen username."
        },
        "photoURL": {
          "type": "string",
          "description": "The URL or Base64 data of the user's profile photo."
        },
        "role": {
          "type": "string",
          "description": "The user's role within the system.",
          "enum": ["admin", "user"]
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the user profile was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp indicating when the user profile was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "createdAt",
        "updatedAt"
      ]
    },
    "CompanyMetadata": {
      "title": "CompanyMetadata",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "Task": {
      "title": "Task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "summary": { "type": "string" },
        "isFavorite": { "type": "boolean" },
        "reminder": { "type": "string" },
        "reminderExpiresAt": { "type": "string" },
        "repositories": { "type": "array", "items": { "type": "string" } },
        "azureWorkItemId": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "prLinks": { "type": "object" },
        "deploymentStatus": { "type": "object" },
        "deploymentDates": { "type": "object" },
        "relevantEnvironments": { "type": "array", "items": { "type": "string" } },
        "developers": { "type": "array", "items": { "type": "string" } },
        "testers": { "type": "array", "items": { "type": "string" } },
        "comments": { "type": "array" },
        "attachments": { "type": "array" },
        "customFields": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "User profile data."
        }
      },
      {
        "path": "/users/{userId}/companies/{companyId}",
        "definition": {
          "entityName": "CompanyMetadata",
          "description": "Metadata for a company owned by the user."
        }
      },
      {
        "path": "/users/{userId}/companies/{companyId}/tasks/{taskId}",
        "definition": {
          "entityName": "Task",
          "description": "Tasks associated with a specific company."
        }
      },
      {
        "path": "/users/{userId}/companies/{companyId}/notes/{noteId}",
        "definition": {
          "entityName": "Note",
          "description": "Notes associated with a specific company."
        }
      },
      {
        "path": "/users/{userId}/companies/{companyId}/logs/{logId}",
        "definition": {
          "entityName": "Log",
          "description": "Activity logs for a specific company."
        }
      },
      {
        "path": "/users/{userId}/companies/{companyId}/settings/uiConfig",
        "definition": {
          "entityName": "UiConfig",
          "description": "Application configuration for a specific company."
        }
      },
      {
        "path": "/users/{userId}/companies/{companyId}/people/developers",
        "definition": {
          "description": "List of developers for a company."
        }
      },
      {
        "path": "/users/{userId}/companies/{companyId}/people/testers",
        "definition": {
          "description": "List of testers for a company."
        }
      },
      {
        "path": "/users/{userId}/companies/{companyId}/reminders/general",
        "definition": {
          "description": "General reminders for a company."
        }
      },
      {
        "path": "/users/{userId}/companies/{companyId}/releases/updates",
        "definition": {
          "description": "Release history for a company."
        }
      }
    ]
  }
}
