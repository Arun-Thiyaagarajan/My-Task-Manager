rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Helper functions for cleaner rules
     */
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    /**
     * USER DATA HIERARCHY
     * Users have full access to their own branch.
     * This includes listing companies, settings, and logs.
     */
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      match /{allPaths=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    /**
     * GLOBAL FEEDBACK SYSTEM
     */
    match /feedback/{feedbackId} {
      allow create: if isSignedIn();
      allow read, update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin();

      match /messages/{messageId} {
        allow read, list, create: if isSignedIn() && (
          get(/databases/$(database)/documents/feedback/$(feedbackId)).data.userId == request.auth.uid || 
          isAdmin()
        );
      }
    }

    /**
     * TEAM COLLABORATION SYSTEM (TASKS)
     * Access is controlled by the task document itself.
     */
    match /tasks/{taskId} {
      // Read access: Owner, accepted collaborators, and pending invitees
      allow read: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid ||
        request.auth.uid in resource.data.collaborators ||
        request.auth.uid in resource.data.pendingInvites
      );

      // Write access: Only Owner and accepted collaborators
      allow write: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid ||
        request.auth.uid in resource.data.collaborators
      );

      // Task Chat: Restricted to owner and collaborators
      match /chat/{messageId} {
        allow read, create: if isSignedIn() && (
          get(/databases/$(database)/documents/tasks/$(taskId)).data.ownerId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/tasks/$(taskId)).data.collaborators
        );
      }
    }

    /**
     * INVITATION TRACKING
     */
    match /invites/{inviteId} {
      // Users can only see invites sent to them or by them
      // Note: Frontend MUST filter queries by toUserId/fromUserId to avoid permission errors
      allow read: if isSignedIn() && (
        resource.data.toUserId == request.auth.uid || 
        resource.data.fromUserId == request.auth.uid
      );
      
      allow create: if isSignedIn();
      
      allow update, delete: if isSignedIn() && (
        resource.data.toUserId == request.auth.uid || 
        resource.data.fromUserId == request.auth.uid
      );
    }
  }
}