
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * TASKFLOW SECURITY RULES
     * 
     * Enforces strict user-ownership and role-based access control.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Robust admin check that handles cases where profile might not exist yet
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      // Allow read/list if it's the owner or an admin
      allow get, list: if isOwner(userId) || isAdmin();
      
      // Allow creation only if the role is set to 'user' (prevents self-promotion on signup)
      allow create: if isOwner(userId) && request.resource.data.role == 'user';

      // Allow updates to own profile, but FORBID changing the 'role' field unless the requester is an admin
      allow update: if isOwner(userId) 
                    && (request.resource.data.role == resource.data.role || isAdmin());

      // Only admins can delete user profiles
      allow delete: if isAdmin();

      // Access to subcollections (companies, tasks, etc.)
      match /companies/{companyId} {
        // Ownership check is prioritized to avoid unnecessary lookups
        allow get, list, create, update, delete: if isOwner(userId) || isAdmin();
        
        match /{allPaths=**} {
          allow get, list, create, update, delete: if isOwner(userId) || isAdmin();
        }
      }
    }
  }
}
