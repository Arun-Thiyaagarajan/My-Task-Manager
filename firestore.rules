
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * TASKFLOW SECURITY RULES
     * 
     * Enforces strict user-ownership. Users can only access their own data
     * stored under /users/{userId}/.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get, list, create, update, delete: if isOwner(userId);

      // Recursive match for all company data
      match /companies/{companyId}/{document=**} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
    }
  }
}
