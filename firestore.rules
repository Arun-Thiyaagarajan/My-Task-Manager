
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * TASKFLOW SECURITY RULES
     * 
     * Enforces strict user-ownership and role-based access control.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Robust admin check that handles cases where profile might not exist yet
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      // Allow read/list if it's the owner or an admin
      allow get, list: if isOwner(userId) || isAdmin();
      
      // Allow creation only if the role is set to 'user' (prevents self-promotion on signup)
      allow create: if isOwner(userId) && request.resource.data.role == 'user';

      // Allow updates to own profile, but FORBID changing the 'role' field unless the requester is an admin
      allow update: if isOwner(userId) 
                    && (request.resource.data.role == resource.data.role || isAdmin());

      // Only admins can delete user profiles
      allow delete: if isAdmin();

      // Allow access to user preferences
      match /preferences/{any=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      // Access to subcollections (companies, tasks, etc.)
      match /companies/{companyId} {
        // Ownership check is prioritized to avoid unnecessary lookups
        allow get, list, create, update, delete: if isOwner(userId) || isAdmin();
        
        match /{allPaths=**} {
          allow get, list, create, update, delete: if isOwner(userId) || isAdmin();
        }
      }
    }

    // Global Feedback Collection Rules
    match /feedback/{feedbackId} {
      // Any signed-in user can submit feedback
      allow create: if isSignedIn();
      
      // Users can only read/update their own reports. Admins see everything.
      allow read, update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      // Admin list access for the Support Inbox
      allow list: if isAdmin();

      // Conversation Messages Subcollection
      match /messages/{messageId} {
        // Access depends on the parent feedback report ownership
        allow read, list, create: if isSignedIn() && (
          get(/databases/$(database)/documents/feedback/$(feedbackId)).data.userId == request.auth.uid || 
          isAdmin()
        );
      }
    }

    // Unified Notification Hub Rules
    match /notifications/{notificationId} {
      // Any user can create a notification (e.g. when submitting feedback or replying)
      allow create: if isSignedIn();
      
      // Users can only access notifications intended for their UID
      // Admins can access notifications addressed to 'admin'
      allow read, update, delete: if isSignedIn() && (
        resource.data.recipientId == request.auth.uid || 
        (resource.data.recipientId == 'admin' && isAdmin())
      );
    }
  }
}
