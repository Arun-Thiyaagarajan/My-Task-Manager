
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * TASKFLOW SECURITY RULES
     * 
     * Enforces strict user-ownership. Users can only access their own data
     * stored under /users/{userId}/.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      // Allow access to the user profile document itself
      allow get, list, create, update, delete: if isOwner(userId);

      // Allow access to the companies collection and all nested documents/subcollections
      match /companies/{companyId} {
        allow get, list, create, update, delete: if isOwner(userId);
        
        match /{allPaths=**} {
          allow get, list, create, update, delete: if isOwner(userId);
        }
      }
    }
  }
}
